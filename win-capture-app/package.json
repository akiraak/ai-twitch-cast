{
  "name": "win-capture-app",
  "version": "1.0.0",
  "description": "AI Twitch Cast - Windows Window Capture & Streaming Server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "download-ffmpeg": "bash scripts/download-ffmpeg.sh",
    "prebuild": "bash scripts/download-ffmpeg.sh",
    "build": "electron-builder --win --dir"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.atc.wincapture",
    "productName": "win-capture-app",
    "win": {
      "target": "dir",
      "sign": false
    },
    "files": [
      "main.js",
      "preload.js",
      "broadcast-preload.js",
      "capture.html",
      "capture-renderer.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      }
    ]
  }
}
