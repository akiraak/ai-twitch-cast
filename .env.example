# Webサーバーポート（デフォルト: 8080）
WEB_PORT=8080

# === OBS版配信（Windows OBS使用時のみ） ===
# ホスト設定: "wsl" を指定するとWSLからWindows側のIPを自動取得
OBS_WS_HOST=wsl
OBS_WS_PORT=4455
OBS_WS_PASSWORD=your_password_here

# VTube Studio（Live2Dアバター使用時のみ）
VTS_HOST=wsl
VTS_PORT=8001
VTS_MODELS_DIR=C:\Program Files (x86)\Steam\steamapps\common\VTube Studio\VTube Studio_Data\StreamingAssets\Live2DModels

# アバター表示アプリ: "vts"（VTube Studio / Live2D）or "vsf"（VSeeFace / VRM）
AVATAR_APP=vsf

# VSeeFace (VMC Protocol) 設定（VRMアバター使用時のみ）
VSF_OSC_HOST=127.0.0.1
VSF_OSC_PORT=39539

# === Twitch ===
# トークンにchannel:manage:broadcastスコープが必要
TWITCH_TOKEN=oauth:your_token_here
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CHANNEL=your_channel_name
# ストリームキー（OBS不要版配信で必要。Twitchダッシュボード→配信→ストリームキーから取得）
TWITCH_STREAM_KEY=live_your_stream_key_here

# === Gemini API ===
GEMINI_API_KEY=your_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_TOPIC_MODEL=gemini-3-flash-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# === TTS ===
# デフォルト音声（Despina等。省略時はコード内デフォルト値を使用）
TTS_VOICE=Despina
# スタイルプロンプト（省略時は言語モード設定から自動生成）
# TTS_STYLE=終始にこにこしているような、柔らかく楽しげなトーンで読み上げてください

# === OBS不要版配信（省略可、デフォルト値あり） ===
# BROADCAST_DISPLAY=:99
# BROADCAST_RESOLUTION=1920x1080
# BROADCAST_FRAMERATE=30
# BROADCAST_VIDEO_BITRATE=3500k
# BROADCAST_AUDIO_BITRATE=128k
# BROADCAST_PRESET=veryfast
